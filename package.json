{
  "name": "oh-my-cursor",
  "version": "0.1.0",
  "description": "Multi-agent orchestration rules for Cursor IDE - inspired by oh-my-claudecode",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "oh-my-cursor": "dist/cli/index.js",
    "omc-cursor": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "rules",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.2.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "cursor",
    "cursor-ide",
    "ai",
    "agent",
    "multi-agent",
    "orchestration",
    "cursor-rules",
    "mdc"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dasomel/oh-my-cursor.git"
  },
  "homepage": "https://github.com/dasomel/oh-my-cursor",
  "bugs": {
    "url": "https://github.com/dasomel/oh-my-cursor/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
